generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  username    String   @unique
  displayName String
  email       String
  avatarUrl   String?
  timezone    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  eventTypes            EventType[]
  availabilitySchedules AvailabilitySchedule[]
  bookings              Booking[]
}

model EventType {
  id                  String   @id @default(uuid())
  hostId              String
  name                String
  slug                String
  durationMinutes     Int
  description         String?
  color               String   @default("#0054cc")
  active              Boolean  @default(true)
  bufferBeforeMinutes Int      @default(0)
  bufferAfterMinutes  Int      @default(0)
  scheduleId          String?
  deletedAt           DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  host            User                  @relation(fields: [hostId], references: [id], onDelete: Cascade)
  schedule        AvailabilitySchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  bookings        Booking[]
  customQuestions CustomQuestion[]

  // NOTE: uniqueness on (hostId, slug) is enforced by a PARTIAL unique index
  // that only applies to rows where deletedAt IS NULL (see migration
  // 20260416_cascade_question_delete_and_partial_slug_unique). That lets a
  // soft-deleted event type's slug be reused on a new event type, which the
  // plain @@unique prevented. Prisma can't express partial uniques natively,
  // so we keep just the btree @@index here and manage uniqueness via SQL.
  @@index([hostId, slug])
  @@index([hostId])
  @@index([scheduleId])
}

model AvailabilitySchedule {
  id        String   @id @default(uuid())
  hostId    String
  name      String   @default("Working Hours")
  timezone  String
  isDefault Boolean  @default(true)
  createdAt DateTime @default(now())

  host       User                 @relation(fields: [hostId], references: [id], onDelete: Cascade)
  rules      AvailabilityRule[]
  overrides  DateOverride[]
  eventTypes EventType[]

  @@index([hostId])
}

model AvailabilityRule {
  id         String @id @default(uuid())
  scheduleId String
  weekday    Int    // 0=Sun..6=Sat
  startTime  String // "HH:mm"
  endTime    String // "HH:mm"

  schedule AvailabilitySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId, weekday])
}

model DateOverride {
  id         String   @id @default(uuid())
  scheduleId String
  date       DateTime @db.Date
  blocks     Json     // [{start:"09:00",end:"12:00"}] or [] for unavailable

  schedule AvailabilitySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, date])
}

model CustomQuestion {
  id          String  @id @default(uuid())
  eventTypeId String
  label       String
  type        String  @default("text") // text | textarea | select
  options     Json?
  required    Boolean @default(false)
  position    Int     @default(0)

  eventType EventType        @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  answers   BookingAnswer[]

  @@index([eventTypeId])
}

model Booking {
  id                      String   @id @default(uuid())
  eventTypeId             String
  hostId                  String
  inviteeName             String
  inviteeEmail            String
  inviteeTimezone         String
  startUtc                DateTime
  endUtc                  DateTime
  status                  String   @default("confirmed") // confirmed | cancelled
  cancellationTokenHash   String
  cancelledAt             DateTime?
  cancelReason            String?
  notes                   String?
  createdAt               DateTime @default(now())

  eventType EventType         @relation(fields: [eventTypeId], references: [id])
  host      User              @relation(fields: [hostId], references: [id])
  answers   BookingAnswer[]

  @@index([hostId, startUtc])
  @@index([eventTypeId, startUtc])
  @@index([inviteeEmail])
}

model BookingAnswer {
  id         String @id @default(uuid())
  bookingId  String
  questionId String
  answer     String

  booking  Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  // onDelete: Cascade matches the hard-delete behaviour in the questions
  // PUT endpoint (the old FK was RESTRICT which meant deleting a question
  // with historical answers would throw 500 instead of cascading).
  question CustomQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}
