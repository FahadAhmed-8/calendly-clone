# Postgres connection string (Neon / Supabase / local Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/calendly_clone?schema=public"

# Admin API key (any random 32+ char string). Required to call /api/admin/*
ADMIN_API_KEY="change-me-to-a-long-random-string"

# Public app URL (used for generating booking links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
