# Postgres connection string (Neon / Supabase / local Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/calendly_clone?schema=public"

# Public app URL (used for generating booking + email links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Email notifications (optional) ---
# When SMTP_HOST is unset, emails are logged to the server console instead
# of being delivered. This keeps local dev frictionless.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Scheduler <no-reply@scheduler.local>"
